---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResourceSubjectList from '../../components/ResourceSubjectList.astro';
import { previousResourceSubjects } from '../../data/learn-resource-subjects';
---

<BaseLayout
  title="Previous Resources | CMS"
  description="Archived Islamic studies materials from past terms at Colorado Muslim Society: aqeedah, usul al-fiqh, usul al-tafsir, fiqh, hadith, and Arabic."
>
  <div class="previous-resources-page">
    <section class="section">
      <div class="container">
        <h1>Previous Resources</h1>
        <p class="muted resources-page-intro">
          Materials from past classes are organized by subject below.
        </p>

        <ResourceSubjectList subjects={previousResourceSubjects} />
      </div>
    </section>
  </div>
</BaseLayout>

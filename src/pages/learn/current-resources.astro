---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResourceSubjectList from '../../components/ResourceSubjectList.astro';
import { learnResourceSubjects } from '../../data/learn-resource-subjects';
---

<BaseLayout
  title="Current Resources | CMS"
  description="Current semester Islamic studies resources at Colorado Muslim Society: aqeedah, usul al-fiqh, usul al-tafsir, fiqh, hadith, and Arabic."
>
  <div class="current-resources-page">
    <section class="section">
      <div class="container">
        <h1>Current Resources</h1>
        <p class="muted resources-page-intro">
          Materials for current classes are organized by subject below.
        </p>

        <ResourceSubjectList subjects={learnResourceSubjects} />
      </div>
    </section>
  </div>
</BaseLayout>

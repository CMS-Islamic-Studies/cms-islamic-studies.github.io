---
import BaseLayout from '../layouts/BaseLayout.astro';

const baseUrl = import.meta.env.BASE_URL;

const resources = [
  { title: 'Quran Education', category: 'Quran', tag: 'Beginner-friendly' },
  { title: 'Salat Basics and Practice', category: 'Islam Essentials', tag: 'Beginner-friendly' },
  { title: 'Sunday School Program', category: 'Youth/Kids', tag: 'For families' },
  { title: 'Islamic Advice and Guidance', category: 'Community Support', tag: 'For families' },
  { title: 'Khatera / Halaqa Talks', category: 'Lectures', tag: 'Video' },
  { title: 'Ramadan Timings PDF', category: 'PDF Resources', tag: 'Download' },
];
---

<BaseLayout title="Classes & Resources" description="Browse classes and Islamic resources at CMS.">
  <section class="section">
    <div class="container">
      <h1>Classes & Resources</h1>
      <p class="muted">
        Islamic learning resources and class content inspired by the current CMS offerings.
      </p>
      <p class="muted">
        <a href={`${baseUrl}learn/signup`}>Registration</a>
        {' · '}
        <a href={`${baseUrl}learn/current-resources`}>Current Resources</a>
        {' · '}
        <a href={`${baseUrl}learn/previous-resources`}>Previous Resources</a>
        {' · '}
        <a href={`${baseUrl}learn/recordings`}>Recordings</a>
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card-grid">
        {resources.map((item) => (
          <article class="card">
            <p class="muted">{item.category}</p>
            <h3>{item.title}</h3>
            <p>
              <span class="muted">Tag:</span> {item.tag}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

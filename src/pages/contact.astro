---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact & Visit" description="Address and visitor information for Colorado Muslim Society.">
  <div class="contact-page">
  <section class="section">
    <div class="container">
      <h1>Contact & Visit the Masjid</h1>
    </div>
  </section>

  <section class="section">
    <div class="container two-col">
      <article class="card">
        <h2>Contact Information</h2>
        <p><strong>Address:</strong> 2071 S Parker Road, Denver, CO 80231</p>
        <p><strong>Phone:</strong> <a href="tel:+13036969800">(303) 696-9800</a></p>
        <p>
          <strong>Email:</strong>
          <a href="mailto:info@coloradomuslimsociety.org">info@coloradomuslimsociety.org</a>
        </p>
      </article>
      <article class="card">
        <h2>Visitor Guidance</h2>
        <p class="muted">New to Masjid Abu Bakr? We are glad to have you join us at CMS.</p>
        <a
          class="btn btn-secondary"
          href="https://maps.google.com/?q=2071+S+Parker+Road,+Denver,+CO+80231"
          target="_blank"
          rel="noreferrer">Open in Google Maps</a
        >
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <article class="card executive-board">
        <h2>Executive Board</h2>
        <div class="board-role">
          <p><strong>Ibrahim Hirbo</strong> — CMS President</p>
          <p>
            <a href="tel:+13036969800">303-696-9800</a> Ext. 102
          </p>
        </div>
        <div class="board-role">
          <p><strong>Iman Jodeh</strong> — Public relations / General Secretary</p>
          <p><a href="tel:+17206081882">720-608-1882</a></p>
        </div>
        <h3 class="shurah-heading">Shurah Members</h3>
        <ul class="shurah-list">
          <li>Amanullah Mommandi, P.E. (Secretary of Shurah)</li>
          <li>Mohammed Ashour (Shura Vice Chairperson)</li>
          <li>Mian Nawaz</li>
          <li>Alam Arain</li>
          <li>Hafedh Ferjani</li>
          <li>Dahir Harjuma</li>
          <li>Emamudin Ghiasi</li>
          <li>Salih Badri</li>
          <li>Abbas Salim</li>
        </ul>
      </article>
    </div>
  </section>
  </div>
</BaseLayout>
